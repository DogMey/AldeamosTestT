# =============================================================================
#  AldeamosTestT — Variables de entorno
#  Copia este archivo a .env y ajusta los valores antes de levantar Docker.
#  NUNCA commitees el archivo .env al repositorio.
# =============================================================================

# ─── MySQL (usado por el Producer) ───────────────────────────────────────────
MYSQL_DATABASE=producer_db
DB_URL=jdbc:mysql://mysql:3306/producer_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change_this_password
DDL_AUTO=update

# ─── MongoDB (usado por el Consumer) ─────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/consumer_db

# ─── RabbitMQ (compartido entre Producer y Consumer) ─────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=producer.exchange
RABBITMQ_ROUTING_KEY=producer.messages
RABBITMQ_QUEUE=producer.queue

# ─── JWT (usado por el Producer) ─────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -base64 32
JWT_SECRET=replace_with_a_secure_random_string_minimum_32_chars
JWT_EXPIRATION_MS=86400000

# ─── Credenciales de la API (usado por el Producer) ──────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_password
