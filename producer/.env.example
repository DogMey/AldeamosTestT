# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# ── Local development (without Docker) ──────────────────────────────────────
#   Option A: source the file before running
#     export $(grep -v '^#' .env | xargs) && mvn spring-boot:run
#   Option B: IntelliJ → Run/Debug Configurations → EnvFile plugin
#   Option C: VS Code → "dotenv" extension + launch.json envFile
#
# ── Docker deployment ────────────────────────────────────────────────────────
#   docker-compose reads .env automatically via `env_file: .env`

# ─── Database ───────────────────────────────────────────────────────────────
MYSQL_DATABASE=aldeamo_db
DB_URL=jdbc:mysql://mysql:3306/aldeamo_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password
DDL_AUTO=update

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=producer.exchange
RABBITMQ_ROUTING_KEY=producer.messages
RABBITMQ_QUEUE=producer.queue

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong secret (min 32 chars): openssl rand -base64 32
JWT_SECRET=replace_with_a_secure_random_string_min_32_chars
JWT_EXPIRATION_MS=86400000

# ─── Auth (simple in-memory user for /auth/login) ───────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=replace_with_a_secure_password
